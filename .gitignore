# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.pytest_cache/

# Compiled binaries (platform-specific — build with feynman install-qgraf / install-looptools)
bin/qgraf
bin/qgraf_pipe
bin/liblooptools.dylib
bin/liblooptools.so
bin/form

# Claude Code session artifacts (transient, never committed)
.claude/

# Compiled outputs
*.pdf
*.log
*.aux

# QGRAF-output .mod files only — our hand-written model files in
# contrib/qgraf/models/ AND feynman_engine/resources/qgraf/models/ are
# explicitly tracked (the latter ships in the pip wheel).
*.mod
!contrib/qgraf/models/*.mod
!feynman_engine/resources/qgraf/models/*.mod

# Secrets / local config
.env
*.local

# macOS
.DS_Store

# Editor
.idea/
.vscode/
*.swp

# PLY (Python Lex-Yacc) auto-generated parser tables.  Tools like MadGraph5
# write `py.py` / `parser.out` in the CWD when first invoked.  A leftover
# `py.py` shadows the standard `py` package and breaks pytest's terminal
# writer (`AttributeError: module 'py' has no attribute 'path'`).  Always exclude.
/py.py
/parser.out

# MadGraph5 process output directories (written to CWD by `mg5_aMC -f`).
# These are large (10s of MB) and not part of the engine — outputs of
# benchmark scripts that should land in /tmp/ or paper/benchmarks/mg5_runs/.
/mg5_*_run/
/mg5_*_run.tar.gz
